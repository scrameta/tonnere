library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity vga_576p50_test is
    port (
        clk27  : in  std_logic;  -- 27 MHz pixel clock
        reset  : in  std_logic;  -- synchronous active-high reset

        hsync  : out std_logic;
        vsync  : out std_logic;
        r      : out std_logic_vector(7 downto 0);
        g      : out std_logic_vector(7 downto 0);
        b      : out std_logic_vector(7 downto 0)
    );
end entity;

architecture rtl of vga_576p50_test is

    -- 576p50 timing @ 27 MHz
    constant H_ACTIVE : integer := 720;
    constant H_FP     : integer := 12;
    constant H_SYNC   : integer := 64;
    constant H_BP     : integer := 68;
    constant H_TOTAL  : integer := H_ACTIVE + H_FP + H_SYNC + H_BP;  -- 864

    constant V_ACTIVE : integer := 576;
    constant V_FP     : integer := 5;
    constant V_SYNC   : integer := 5;
    constant V_BP     : integer := 39;
    constant V_TOTAL  : integer := V_ACTIVE + V_FP + V_SYNC + V_BP;  -- 625

    signal h_count : integer range 0 to H_TOTAL - 1 := 0;
    signal v_count : integer range 0 to V_TOTAL - 1 := 0;

    signal active_video : std_logic;
    signal r_i, g_i, b_i : std_logic_vector(7 downto 0) := (others => '0');

begin

    --------------------------------------------------------------------
    -- Timing generator
    --------------------------------------------------------------------
    process(clk27)
    begin
        if rising_edge(clk27) then
            if reset = '1' then
                h_count <= 0;
                v_count <= 0;
            else
                if h_count = H_TOTAL - 1 then
                    h_count <= 0;
                    if v_count = V_TOTAL - 1 then
                        v_count <= 0;
                    else
                        v_count <= v_count + 1;
                    end if;
                else
                    h_count <= h_count + 1;
                end if;
            end if;
        end if;
    end process;

    active_video <= '1' when (h_count < H_ACTIVE and v_count < V_ACTIVE) else '0';

    --------------------------------------------------------------------
    -- Syncs
    -- Active-high, matching your flat panel's preference
    --------------------------------------------------------------------
    hsync <= '1' when (h_count >= H_ACTIVE + H_FP and
                       h_count <  H_ACTIVE + H_FP + H_SYNC) else '0';

    vsync <= '1' when (v_count >= V_ACTIVE + V_FP and
                       v_count <  V_ACTIVE + V_FP + V_SYNC) else '0';

    --------------------------------------------------------------------
    -- Test pattern generator
    --------------------------------------------------------------------
    process(h_count, v_count, active_video)
        variable x, y         : integer;
        variable bar          : integer;
        variable section      : integer;

        variable rv, gv, bv   : unsigned(7 downto 0);
        variable ramp_x       : unsigned(7 downto 0);
        variable ramp_y       : unsigned(7 downto 0);
        variable local_x_8    : unsigned(7 downto 0);

        variable border       : boolean;
        variable grid         : boolean;

        -- HSV/rainbow helpers
        variable hue          : integer;  -- 0..255
        variable seg          : integer;  -- 0..5
        variable frac         : integer;  -- 0..255 within segment
        variable p            : integer;
        variable q            : integer;
        variable t            : integer;

        -- For 256-step grayscale
        variable gray_step    : integer;
        variable gray_val     : unsigned(7 downto 0);
    begin
        rv := (others => '0');
        gv := (others => '0');
        bv := (others => '0');

        if active_video = '1' then
            x := h_count;
            y := v_count;

            border := (x = 0) or (x = H_ACTIVE - 1) or
                      (y = 0) or (y = V_ACTIVE - 1);

            grid := ((x mod 32) = 0) or ((y mod 32) = 0);

            ramp_x := to_unsigned((x * 255) / (H_ACTIVE - 1), 8);
            ramp_y := to_unsigned((y * 255) / (V_ACTIVE - 1), 8);

            if border then
                rv := x"FF";
                gv := x"FF";
                bv := x"FF";

            elsif y < (V_ACTIVE / 2) then
                ----------------------------------------------------------------
                -- TOP HALF: 8 vertical colour bars
                ----------------------------------------------------------------
                bar := x / (H_ACTIVE / 8);

                case bar is
                    when 0 =>
                        rv := x"FF"; gv := x"FF"; bv := x"FF"; -- white
                    when 1 =>
                        rv := x"FF"; gv := x"FF"; bv := x"00"; -- yellow
                    when 2 =>
                        rv := x"00"; gv := x"FF"; bv := x"FF"; -- cyan
                    when 3 =>
                        rv := x"00"; gv := x"FF"; bv := x"00"; -- green
                    when 4 =>
                        rv := x"FF"; gv := x"00"; bv := x"FF"; -- magenta
                    when 5 =>
                        rv := x"FF"; gv := x"00"; bv := x"00"; -- red
                    when 6 =>
                        rv := x"00"; gv := x"00"; bv := x"FF"; -- blue
                    when others =>
                        rv := x"00"; gv := x"00"; bv := x"00"; -- black
                end case;

            else
                ----------------------------------------------------------------
                -- BOTTOM HALF split into 4 equal sections
                ----------------------------------------------------------------
                section := x / 180;  -- 720 / 4

                case section is

                    ----------------------------------------------------------------
                    -- Section 0: 256-step greyscale ramp
                    ----------------------------------------------------------------
                    when 0 =>
                        -- 180 pixels wide, so several pixels per grey code.
                        gray_step := (x * 256) / 180;
                        if gray_step > 255 then
                            gray_step := 255;
                        end if;
                        gray_val := to_unsigned(gray_step, 8);
                        rv := gray_val;
                        gv := gray_val;
                        bv := gray_val;

                    ----------------------------------------------------------------
                    -- Section 1: separate R, G, B ramps
                    -- vertically split into 3 stripes
                    ----------------------------------------------------------------
                    when 1 =>
                        local_x_8 := to_unsigned(((x - 180) * 255) / 179, 8);

                        if y < (V_ACTIVE/2 + V_ACTIVE/6) then
                            -- Red ramp
                            rv := local_x_8;
                            gv := (others => '0');
                            bv := (others => '0');

                        elsif y < (V_ACTIVE/2 + 2*V_ACTIVE/6) then
                            -- Green ramp
                            rv := (others => '0');
                            gv := local_x_8;
                            bv := (others => '0');

                        else
                            -- Blue ramp
                            rv := (others => '0');
                            gv := (others => '0');
                            bv := local_x_8;
                        end if;

                    ----------------------------------------------------------------
                    -- Section 2: HSV-style rainbow fade
                    ----------------------------------------------------------------
                    when 2 =>
                        hue := ((x - 360) * 255) / 179;  -- 0..255 across section

                        -- map hue into 6 segments
                        seg  := (hue * 6) / 256;              -- 0..5
                        frac := ((hue * 6) mod 256);          -- 0..255

                        p := 0;
                        q := 255 - frac;
                        t := frac;

                        case seg is
                            when 0 =>  -- red -> yellow
                                rv := to_unsigned(255, 8);
                                gv := to_unsigned(t,   8);
                                bv := to_unsigned(p,   8);

                            when 1 =>  -- yellow -> green
                                rv := to_unsigned(q,   8);
                                gv := to_unsigned(255, 8);
                                bv := to_unsigned(p,   8);

                            when 2 =>  -- green -> cyan
                                rv := to_unsigned(p,   8);
                                gv := to_unsigned(255, 8);
                                bv := to_unsigned(t,   8);

                            when 3 =>  -- cyan -> blue
                                rv := to_unsigned(p,   8);
                                gv := to_unsigned(q,   8);
                                bv := to_unsigned(255, 8);

                            when 4 =>  -- blue -> magenta
                                rv := to_unsigned(t,   8);
                                gv := to_unsigned(p,   8);
                                bv := to_unsigned(255, 8);

                            when others =>  -- magenta -> red
                                rv := to_unsigned(255, 8);
                                gv := to_unsigned(p,   8);
                                bv := to_unsigned(q,   8);
                        end case;

                        -- apply vertical value fade: bottom brighter, top dimmer
                        rv := shift_right(rv * resize(ramp_y, 16), 8)(7 downto 0);
                        gv := shift_right(gv * resize(ramp_y, 16), 8)(7 downto 0);
                        bv := shift_right(bv * resize(ramp_y, 16), 8)(7 downto 0);

                    ----------------------------------------------------------------
                    -- Section 3: combined colour gradient
                    ----------------------------------------------------------------
                    when others =>
                        rv := to_unsigned(((x - 540) * 255) / 179, 8);
                        gv := ramp_y;
                        bv := not rv;
                end case;
            end if;

            -- Subtle grid overlay
            if grid then
                rv := rv or x"10";
                gv := gv or x"10";
                bv := bv or x"10";
            end if;

        else
            rv := (others => '0');
            gv := (others => '0');
            bv := (others => '0');
        end if;

        r_i <= std_logic_vector(rv);
        g_i <= std_logic_vector(gv);
        b_i <= std_logic_vector(bv);
    end process;

    r <= r_i;
    g <= g_i;
    b <= b_i;

end architecture;
